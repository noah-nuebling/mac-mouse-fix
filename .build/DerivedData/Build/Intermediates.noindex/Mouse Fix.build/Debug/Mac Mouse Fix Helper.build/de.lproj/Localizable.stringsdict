			<string>%2$@ wird nicht länger von Mac Mouse Fix abgefangen</string>
			<key>other</key>
			<string>%2$@ werden nicht länger von Mac Mouse Fix abgefangen</string>
		</dict>
	</dict>
	<key>capture-toast.buttons.uncaptured.hint</key>
	<dict>
		<key>NSStringLocalizedFormatKey</key>
