			<key>NSStringFormatValueTypeKey</key>
			<string>d</string>
			<key>one</key>
			<string>Andere Apps können die Taste nicht mehr sehen</string>
			<key>other</key>
			<string>Andere Apps können diese Tasten nicht mehr sehen</string>
		</dict>
	</dict>
	<key>capture-toast.buttons.uncaptured.body</key>
