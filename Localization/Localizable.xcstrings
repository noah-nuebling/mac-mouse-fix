    "trial-notif.body" : {
      "comment" : "",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مرحبًا! لقد استخدمت Mac Mouse Fix لمدة **%1$d يومًا** حتى الآن. آمل أنك تستمتع به!\n\nإذا أردت الاستمرار في استخدام Mac Mouse Fix، يمكنك [شراؤه الآن](%2$@)."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hola! Fa **%1$d dies** que fas servir Mac Mouse Fix. Espero que n'estiguis gaudint!\n\nSi vols continuar usant Mac Mouse Fix, pots [comprar-lo ara](%2$@)."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ahoj! Používáš Mac Mouse Fix už **%1$d dní**. Doufám, že se ti líbí!\n\nPokud chceš Mac Mouse Fix používat dál, můžeš si ho [koupit tady](%2$@)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hallo! Du nutzt Mac Mouse Fix jetzt seit **%1$d Tagen**. Ich hoffe, es gefällt dir!\n\nWenn du Mac Mouse Fix weiter nutzen möchtest, kannst du es [jetzt kaufen](%2$@)."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Γεια σου! Χρησιμοποιείς το Mac Mouse Fix εδώ και **%1$d ημέρες**. Ελπίζω να σου αρέσει!\n\nΑν θέλεις να συνεχίσεις να χρησιμοποιείς το Mac Mouse Fix, μπορείς να [το αγοράσεις τώρα](%2$@)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
