    "license-toast.no-internet" : {
      "comment" : "",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyskytl se **problém s internetovým připojením**\n\nUjisti se, že je tvůj počítač online a žádný firewall neblokuje Mac Mouse Fix v připojení k internetu.\n\nPokud to problém nevyřeší, kontaktuj mě [zde](%@)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es gibt ein **Problem mit der Internetverbindung**\n\nStell sicher, dass dein Computer online ist und keine Firewalls Mac Mouse Fix am Verbinden mit dem Internet hindern.\n\nWenn das das Problem nicht löst, kontaktiere mich [hier](%@)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "There is a **problem with the internet connection**\n\nMake sure your computer is online and no firewalls are blocking Mac Mouse Fix from connecting to the internet.\n\nIf this doesn't solve the problem, contact me [here](%@)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hay un **problema con la conexión a Internet**\n\nAsegúrate de que tu ordenador esté conectado y de que ningún cortafuegos esté bloqueando la conexión de Mac Mouse Fix a Internet.\n\nSi esto no resuelve el problema, contáctame [aquí](%@)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il y a un **problème avec la connexion internet**\n\nAssurez-vous que votre ordinateur est en ligne et qu'aucun pare-feu ne bloque Mac Mouse Fix pour se connecter à internet.\n\nSi cela ne résout pas le problème, contactez-moi [ici](%@)."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Há um **problema com a conexão de internet**\n\nCertifique-se de que seu computador está online e que nenhum firewall está bloqueando a conexão do Mac Mouse Fix com a internet.\n\nSe isso não resolver o problema, entre em contato comigo [aqui](%@)."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**Проблема с интернет-соединением**\n\nУбедись, что твой компьютер подключён к интернету и брандмауэры не блокируют подключение Mac Mouse Fix.\n\nЕсли это не поможет, свяжись со мной [здесь](%@)."
          }
        }
      }
    },
    "license-toast.server-response-invalid" : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyskytl se **problém s licenčním serverem**\n\nZkus to prosím později.\n\nPokud problém přetrvává, kontaktuj mě [zde](%@)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es gibt ein **Problem mit dem Lizenzserver**\n\nBitte versuche es später erneut.\n\nWenn das Problem weiterhin besteht, kontaktiere mich [hier](%@)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "There is a **problem with the license server**\n\nPlease try again later.\n\nIf the issue persists, contact me [here](%@)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hay un **problema con el servidor de licencias**\n\nPor favor, inténtalo de nuevo más tarde.\n\nSi el problema persiste, contáctame [aquí](%@)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il y a un **problème avec le serveur de licences**\n\nVeuillez réessayer plus tard.\n\nSi le problème persiste, contactez-moi [ici](%@)."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Há um **problema com o servidor de licenças**\n\nPor favor, tente novamente mais tarde.\n\nSe o problema persistir, entre em contato comigo [aqui](%@)."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**Проблема с сервером лицензий**\n\nПожалуйста, попробуй позже.\n\nЕсли проблема сохраняется, свяжись со мной [здесь](%@)."
          }
        }
      }
    },
