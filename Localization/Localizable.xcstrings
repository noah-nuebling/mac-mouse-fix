    "license-toast.unknown-key" : {
      "comment" : "",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' ليس مفتاح ترخيص صالحًا\n\nتأكد من إدخال مفتاح Mac Mouse Fix تمامًا كما استلمته."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' no és una clau de llicència vàlida\n\nAssegura't d'introduir la teva clau de Mac Mouse Fix exactament tal com la vas rebre."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' není platný licenční klíč\n\nUjisti se, že zadáváš svůj klíč pro Mac Mouse Fix přesně tak, jak jsi ho obdržel."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' ist kein gültiger Lizenzschlüssel\n\nStell sicher, dass du deinen Mac Mouse Fix Schlüssel genau so eingibst, wie du ihn erhalten hast."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' δεν είναι έγκυρος κωδικός άδειας\n\nΒεβαιώσου ότι εισάγεις τον κωδικό Mac Mouse Fix ακριβώς όπως τον έλαβες."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' is not a valid license key\n\nMake sure you enter your Mac Mouse Fix key exactly as you received it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' no es una clave de licencia válida\n\nAsegúrate de introducir tu clave de Mac Mouse Fix exactamente como la recibiste."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« **%@** » n'est pas une clé de licence valide\n\nVeillez à saisir votre clé Mac Mouse Fix exactement telle que vous l'avez reçue."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' אינו מפתח רישיון תקף\n\nודא שאתה מזין את מפתח Mac Mouse Fix שלך בדיוק כפי שקיבלת אותו."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' एक मान्य लाइसेंस कुंजी नहीं है\n\nसुनिश्चित करें कि आपने अपनी Mac Mouse Fix कुंजी ठीक वैसे ही दर्ज की है जैसी आपको मिली थी।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A(z) '**%@**' nem érvényes licenckulcs\n\nGyőződj meg róla, hogy pontosan úgy adod meg a Mac Mouse Fix kulcsodat, ahogy megkaptad."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' bukan kunci lisensi yang valid\n\nPastikan Anda memasukkan kunci Mac Mouse Fix persis seperti yang Anda terima."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' non è una chiave di licenza valida\n\nAssicurati di inserire la tua chiave di Mac Mouse Fix esattamente come l'hai ricevuta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「**%@**」は有効なライセンスキーではありません\n\nMac Mouse Fixのキーを受け取った通りに正確に入力しているか確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**'은(는) 유효한 라이선스 키가 아닙니다\n\nMac Mouse Fix 키를 받은 그대로 정확히 입력했는지 확인해 주세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' is geen geldige licentiesleutel\n\nZorg ervoor dat je je Mac Mouse Fix-sleutel precies invoert zoals je deze hebt ontvangen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' nie jest prawidłowym kluczem licencyjnym\n\nUpewnij się, że wpisujesz swój klucz Mac Mouse Fix dokładnie tak, jak go otrzymałeś."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' não é uma chave de licença válida\n\nCertifique-se de inserir sua chave do Mac Mouse Fix exatamente como você a recebeu."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' não é uma chave de licença válida\n\nCertifica-te de que introduzes a tua chave do Mac Mouse Fix exatamente como a recebeste."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' nu este o cheie de licență validă\n\nAsigură-te că introduci cheia ta Mac Mouse Fix exact așa cum ai primit-o."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' не является действительным лицензионным ключом\n\nУбедись, что ты вводишь ключ Mac Mouse Fix точно так, как получил его."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' är inte en giltig licensnyckel\n\nKontrollera att du anger din Mac Mouse Fix-nyckel exakt som du fick den."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' ไม่ใช่คีย์ใบอนุญาตที่ถูกต้อง\n\nตรวจสอบให้แน่ใจว่าคุณป้อนคีย์ Mac Mouse Fix ตรงตามที่ได้รับ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' geçerli bir lisans anahtarı değil\n\nMac Mouse Fix anahtarınızı tam olarak aldığınız şekilde girdiğinizden emin olun."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' не є дійсним ліцензійним ключем\n\nПереконайся, що ти вводиш ключ Mac Mouse Fix саме так, як отримав його."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'**%@**' không phải là khóa giấy phép hợp lệ\n\nHãy đảm bảo bạn nhập khóa Mac Mouse Fix chính xác như bạn đã nhận được."
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「**%@**」不是有效的授權金鑰\n\n請確保輸入的是你收到的 Mac Mouse Fix 金鑰，並且沒有輸入錯誤。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"**%@**\"不是有效的许可证密钥\n\n请确保你输入的 Mac Mouse Fix 密钥与收到的完全一致。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「**%@**」不是有效的授權金鑰\n\n請確認你輸入的是收到的 Mac Mouse Fix 金鑰，並且沒有輸入錯誤。"
          }
        }
      }
    },
    "license-toast.unknown-reason" : {
      "comment" : "",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فشل تفعيل ترخيصك لـ**أسباب غير معروفة**\n\nيرجى كتابة **تقرير خطأ** [هنا](%@)"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'activació de la teva llicència ha fallat per **raons desconegudes**\n\nSi us plau, escriu un **informe d'error** [aquí](%@)"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktivace licence selhala z **neznámých důvodů**\n\nNapiš prosím **hlášení o chybě** [zde](%@)"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Aktivierung deiner Lizenz ist aus **unbekannten Gründen** fehlgeschlagen\n\nBitte schreibe einen **Fehlerbericht** [hier](%@)"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η ενεργοποίηση της άδειας απέτυχε για **άγνωστους λόγους**\n\nΠαρακαλώ γράψε μια **Αναφορά Σφάλματος** [εδώ](%@)"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activating your license failed for **unknown reasons**\n\nPlease write a **Bug Report** [here](%@)"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La activación de tu licencia ha fallado por **razones desconocidas**\n\nPor favor, escribe un **informe de error** [aquí](%@)"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'activation de votre licence a échoué pour des **raisons inconnues**\n\nVeuillez écrire un **rapport de bug** [ici](%@)"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הפעלת הרישיון שלך נכשלה **מסיבות לא ידועות**\n\nאנא כתוב **דוח באג** [כאן](%@)"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपके लाइसेंस की सक्रियता **अज्ञात कारणों** से विफल हुई\n\nकृपया [यहाँ](%@) **बग रिपोर्ट** लिखें"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A licenc aktiválása **ismeretlen okból** sikertelen volt\n\nKérlek, írj egy **hibajelentést** [ide](%@)"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktivasi lisensi gagal karena **alasan tidak dikenal**\n\nSilakan tulis **laporan bug** [di sini](%@)"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'attivazione della licenza non è riuscita per **motivi sconosciuti**\n\nScrivi una **segnalazione bug** [qui](%@)"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**不明な理由**でライセンスの有効化に失敗しました\n\n[こちら](%@)から**バグ報告**をお願いします"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**알 수 없는 이유**로 라이선스 활성화에 실패했습니다\n\n[여기](%@)에서 **버그 제보**를 해주세요"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Het activeren van je licentie is mislukt om **onbekende redenen**\n\nSchrijf alsjeblieft een **bugrapport** [hier](%@)"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktywacja licencji nie powiodła się z **nieznanych przyczyn**\n\nProszę, napisz **zgłoszenie błędu** [tutaj](%@)"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A ativação da sua licença falhou por **motivos desconhecidos**\n\nPor favor, escreva um **relatório de bug** [aqui](%@)"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A ativação da tua licença falhou por **razões desconhecidas**\n\nPor favor, escreve um **relatório de erro** [aqui](%@)"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activarea licenței tale a eșuat din **motive necunoscute**\n\nTe rog să scrii un **raport de eroare** [aici](%@)"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Активация лицензии не удалась по **неизвестным причинам**\n\nПожалуйста, напиши **отчёт об ошибке** [здесь](%@)"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktivering av din licens misslyckades av **okända skäl**\n\nSkriv gärna en **felrapport** [här](%@)"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "การเปิดใช้งานใบอนุญาตล้มเหลวเนื่องจาก**สาเหตุที่ไม่ทราบ**\n\nกรุณาเขียน**รายงานข้อผิดพลาด**[ที่นี่](%@)"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lisansınızın etkinleştirilmesi **bilinmeyen nedenlerle** başarısız oldu\n\n[Buradan](%@) bir **hata raporu** yazın lütfen"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Активація ліцензії не вдалася з **невідомих причин**\n\nБудь ласка, напиши **звіт про помилку** [тут](%@)"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kích hoạt giấy phép thất bại vì **lý do không xác định**\n\nVui lòng viết **báo cáo lỗi** [tại đây](%@)"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "授權啟用因**不明原因**失敗\n\n請[在這裏](%@)撰寫**錯誤報告**"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "许可证激活因**未知原因**失败\n\n请在[这里](%@)提交**错误报告**"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
