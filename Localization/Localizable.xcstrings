    "capture-toast.button-name.middle" : {
      "comment" : "Note: These button names will be inserted into other \"capture-toast.buttons.[...]\" strings.\n\nExample: \nMiddle Button and Button 4 are now captured by Mac Mouse Fix.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Middle Button"
          }
        }
      }
    },
    "capture-toast.button-name.numbered" : {
      "comment" : "Note: These strings can be joined programmatically if multiple buttons are captured. For visual consistency, capitalization of the these button-name strings should follow the capitalization of the trigger.substring.button-name.[...] strings.\nSee trigger.substring.button-modifier.2",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Button %@"
          }
        }
      }
    },
    "capture-toast.button-name.primary" : {
      "comment" : "",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Primary Button"
          }
        }
      }
    },
    "capture-toast.button-name.secondary" : {
      "comment" : "",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Secondary Button"
          }
        }
      }
    },
    "capture-toast.buttons.captured.body" : {
      "comment" : "Note: This is a \"pluralizable\" string, which means it has different versions depending on how many buttons the string is talking about.\n\nNote: \"%2$@\" will be replaced with the names of the captured buttons.\nExample where those buttons are \"Middle Button\" and \"Button 4\":\"Middle Button and Button 4 are now captured by Mac Mouse Fix.\"\n\nNote: \n\nNote: If you're editing this in Xcode: Click the disclosure triangles (>) to edit the different versions of the string. Do not localize or modify \"@pluralizable\" - it's just a placeholder. \n",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%#@pluralizable@"
          },
          "substitutions" : {
            "pluralizable" : {
              "formatSpecifier" : "d",
              "variations" : {
                "plural" : {
                  "one" : {
                    "stringUnit" : {
                      "state" : "translated",
                      "value" : "%2$@ is now captured by Mac Mouse Fix"
                    }
                  },
                  "other" : {
                    "stringUnit" : {
                      "state" : "translated",
                      "value" : "%2$@ are now captured by Mac Mouse Fix"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "capture-toast.buttons.captured.hint" : {
      "comment" : "Note: The core idea that we want to convey with these ui strings is that, from now on, the button is being 'intercepted' by Mac Mouse Fix. We used the word 'capture' instead of 'intercept' since I think it sounds nicer in English. In your language, you might want to use something closer to 'intercept'.\n\nAlso see: The CapturedButtonsMMF3 document which explains the concept in more detail.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%#@pluralizable@"
          },
          "substitutions" : {
            "pluralizable" : {
              "formatSpecifier" : "d",
              "variations" : {
                "plural" : {
                  "one" : {
                    "stringUnit" : {
                      "state" : "translated",
                      "value" : "Other apps can't see the button anymore"
                    }
                  },
                  "other" : {
                    "stringUnit" : {
                      "state" : "translated",
                      "value" : "Other apps can't see these buttons anymore"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "capture-toast.buttons.link" : {
      "comment" : "Note: This links to the CapturedButtonsMMF3 document.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[Learn More](%@)"
          }
        }
      }
    },
    "capture-toast.buttons.uncaptured.body" : {
      "comment" : ".",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%#@pluralizable@"
          },
          "substitutions" : {
            "pluralizable" : {
              "formatSpecifier" : "d",
              "variations" : {
                "plural" : {
                  "one" : {
                    "stringUnit" : {
                      "state" : "translated",
                      "value" : "%2$@ is no longer captured by Mac Mouse Fix"
                    }
                  },
                  "other" : {
                    "stringUnit" : {
                      "state" : "translated",
                      "value" : "%2$@ are no longer captured by Mac Mouse Fix"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "capture-toast.buttons.uncaptured.hint" : {
      "comment" : ".",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%#@pluralizable@"
          },
          "substitutions" : {
